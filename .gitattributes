# Auto-detect text files and normalize line endings
* text=auto

# Source files
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.txt text eol=lf
*.toml text eol=lf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Make
Makefile text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pyc binary
*.pyo binary
