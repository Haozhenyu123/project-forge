{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Haozhenyu123/project-forge/docs/schemas/superpowers-handoff.schema.json",
  "title": "Project Forge Superpowers Handoff",
  "type": "object",
  "required": ["schema_version", "kind", "project", "artifacts", "evidence", "harness", "superpowers", "boundary"],
  "properties": {
    "schema_version": {"const": 2},
    "kind": {"const": "project-forge.superpowers-handoff"},
    "project": {
      "type": "object",
      "required": ["slug", "goal", "primary_stack"],
      "properties": {
        "slug": {"type": "string"},
        "goal": {"type": "string"},
        "primary_stack": {"type": "string"},
        "secondary_stacks": {"type": "array", "items": {"type": "string"}}
      }
    },
    "artifacts": {"type": "object"},
    "evidence": {"type": "array", "items": {"type": "object"}},
    "harness": {
      "type": "object",
      "required": ["primary", "secondary", "required_commands"],
      "properties": {
        "primary": {"type": "object"},
        "secondary": {"type": "array", "items": {"type": "object"}},
        "required_commands": {"type": "array", "items": {"type": "string"}}
      }
    },
    "readiness": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "verification_report": {"type": "string"}
      }
    },
    "compatibility": {"type": "object"},
    "superpowers": {
      "type": "object",
      "required": ["assignment", "first_task", "acceptance_criteria", "guardrails", "consume_steps"],
      "properties": {
        "assignment": {"type": "string"},
        "first_task": {"type": "string"},
        "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
        "guardrails": {"type": "array", "items": {"type": "string"}},
        "open_questions": {"type": "array", "items": {"type": "string"}},
        "consume_steps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "boundary": {
      "type": "object",
      "required": ["project_forge_owns", "superpowers_owns"],
      "properties": {
        "project_forge_owns": {"type": "array", "items": {"type": "string"}},
        "superpowers_owns": {"type": "array", "items": {"type": "string"}}
      }
    },
    "creative_decision": {"type": "object"},
    "inventory": {"type": "object"},
    "risks": {"type": "array", "items": {"type": "object"}},
    "effort_estimate": {"type": "object"},
    "loop": {
      "type": "object",
      "description": "Optional Loop Engine metadata (v0.4.0+)",
      "properties": {
        "episode_id": {"type": "string"},
        "iteration": {"type": "integer"},
        "trigger_signal": {"type": "string"},
        "decision_hash": {"type": "string"},
        "latest_report": {"type": "string"},
        "feedback_location": {"type": "string"},
        "current_status": {"enum": ["idle", "collecting", "evaluating", "revising", "handoff_ready", "awaiting_feedback", "blocked", "failed"]}
      }
    }
  }
}
