{
  "description": "Project Forge session startup context for Codex and Claude Code.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python {{pluginRoot}}/scripts/runtime/session_start.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}