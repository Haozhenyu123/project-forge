{
  "name": "FastAPI",
  "kind": "fastapi",
  "aliases": [
    "fastapi",
    "python api"
  ],
  "detection": {
    "files": [
      "pyproject.toml",
      "requirements.txt",
      "main.py"
    ],
    "dependencies": [],
    "exclude_dependencies": [],
    "has_bin": false,
    "match_content": [
      "fastapi"
    ]
  },
  "commands": {
    "install": [
      "python",
      "-m",
      "pip",
      "install",
      "-r",
      "requirements.txt"
    ],
    "test": [
      "python",
      "-m",
      "pytest"
    ],
    "lint": [
      "python",
      "-m",
      "ruff",
      "check",
      "."
    ],
    "typecheck": [
      "python",
      "-m",
      "mypy",
      "."
    ],
    "build": [
      "python",
      "-m",
      "compileall",
      "app"
    ],
    "run": [
      "python",
      "-m",
      "uvicorn",
      "app.main:app",
      "--reload"
    ],
    "smoke": [
      "python",
      "-m",
      "pytest",
      "tests/smoke"
    ]
  },
  "ci": {
    "matrix": [
      "ubuntu-latest"
    ],
    "python-version": "3.12"
  }
}