{
  "name": "Flutter",
  "kind": "flutter",
  "aliases": [
    "flutter",
    "dart"
  ],
  "detection": {
    "files": [
      "pubspec.yaml"
    ],
    "dependencies": [
      "flutter"
    ],
    "exclude_dependencies": [],
    "has_bin": false
  },
  "commands": {
    "install": [
      "flutter",
      "pub",
      "get"
    ],
